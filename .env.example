# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/vietcarbon_ai?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=change_this_to_a_strong_secret

# Groq AI Brain
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# AssemblyAI Streaming STT (optional for advanced voice pipeline)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# ElevenLabs Premium Voice for FRIDAY (recommended)
# Required permissions while creating API key:
# Text to Speech -> Access, Voices -> Read, Models -> Access
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.85
ELEVENLABS_STYLE=0.35

# Free/Open-source female voice TTS: run local Chatterbox server and paste URL
# Example: http://localhost:8000
CHATTERBOX_TTS_URL=
CHATTERBOX_VOICE=female
CHATTERBOX_EXAGGERATION=0.65
CHATTERBOX_CFG_WEIGHT=0.5

# Gmail SMTP for email automation
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_digit_gmail_app_password

PORT=5000
FRONTEND_URL=http://localhost:5173

# SMTP for citizen OTP and report emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_16_digit_app_password
SMTP_FROM=yourgmail@gmail.com
